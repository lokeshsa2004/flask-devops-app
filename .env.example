# Copy to ".env" for local overrides (never commit .env).

# Flask
SECRET_KEY=change-me-in-production
FLASK_ENV=development

# Database (Compose uses MySQL; local default is SQLite under ./instance/)
# SQLite (default if unset):
# DATABASE_URL=sqlite:////absolute/path/to/instance/stackforge.db
#
# MySQL (Docker Compose service name "db"):
DATABASE_URL=mysql+pymysql://app:app@127.0.0.1:3306/stackforge

# Docker image tag used by compose "flask-app" service
APP_IMAGE=flask-devops-app:local
